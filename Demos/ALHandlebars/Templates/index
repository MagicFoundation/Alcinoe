<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>{{title}}</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
           font-size: 16px; color: #333; margin: 0 auto; max-width: 760px; padding: 20px; line-height: 1.5; }
    .hero { border-bottom: 2px solid #eee; margin-bottom: 1.5em; }
    .hero h1 { margin-bottom: 0.1em; }
    .tagline { color: #888; margin-top: 0; }
    .badge { display: inline-block; padding: 2px 10px; border-radius: 10px; background: #eee; font-size: 0.85em; }
    .badge-admin { background: #2d7; color: #fff; }
    table { border-collapse: collapse; width: 100%; }
    th, td { border: 1px solid #ddd; padding: 6px 10px; text-align: left; }
    th { background: #f6f6f6; }
    code { background: #f4f4f4; padding: 1px 4px; border-radius: 3px; }
    footer small { color: #999; }
  </style>
</head>
<body>

{{> header}}

<main>

  {{#with user}}
    <h2>Hello {{firstname}} {{lastname}}!</h2>
    {{#if admin}}
      <p class="badge badge-admin">Administrator</p>
    {{else}}
      <p class="badge">Standard user</p>
    {{/if}}
    <p>Age: {{age}} &middot; Lives in {{address.city}}, {{address.country}}</p>
    <p>Custom <code>shout</code> helper: <b>{{shout firstname}}</b></p>
    <p>Escaped (double-brace) output: {{bio}}</p>
    <p>Raw (triple-brace) output: {{{bio}}}</p>

    <h3>Roles</h3>
    <ul>
    {{#each roles}}
      <li>#{{@index}} &mdash; {{this}}{{#if @first}} <em>(first)</em>{{/if}}{{#if @last}} <em>(last)</em>{{/if}}</li>
    {{else}}
      <li><em>No roles assigned</em></li>
    {{/each}}
    </ul>
  {{/with}}

  <h3>Products</h3>
  <table>
    <tr><th>#</th><th>Name</th><th>Price</th><th>Availability</th></tr>
    {{#each products}}
    <tr>
      <td>{{@index}}</td>
      <td>{{name}}</td>
      <td>{{price}} &euro;</td>
      <td>{{#if (gt stock 0)}}In stock ({{stock}}){{else}}Out of stock{{/if}}</td>
    </tr>
    {{/each}}
  </table>

  <h3>Subexpressions &amp; helpers</h3>
  <p>{{#if (eq user.firstname "John")}}Welcome back, John!{{else}}Who are you?{{/if}}</p>
  <p>Full name (concat): {{concat user.firstname " " user.lastname}}</p>

</main>

{{> footer}}

</body>
</html>

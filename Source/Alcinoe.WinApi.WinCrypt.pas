  _SSL_KEY_PIN_EXTRA_CERT_CHAIN_POLICY_PARA = record
    cbSize: DWORD;
    dwReserved: DWORD;
    pwszServerName: PCWSTR;
  end;
  SSL_KEY_PIN_EXTRA_CERT_CHAIN_POLICY_PARA = _SSL_KEY_PIN_EXTRA_CERT_CHAIN_POLICY_PARA;
  PSSL_KEY_PIN_EXTRA_CERT_CHAIN_POLICY_PARA = ^_SSL_KEY_PIN_EXTRA_CERT_CHAIN_POLICY_PARA;


    IssuerUniqueId: CRYPT_BIT_BLOB;
    SubjectUniqueId: CRYPT_BIT_BLOB;
    cExtension: DWORD;
    rgExtension: PCERT_EXTENSION;
  end;
  CERT_INFO = _CERT_INFO;
  PCERT_INFO = ^_CERT_INFO;
  PPCERT_INFO = ^PCERT_INFO;
// certenrolls_end


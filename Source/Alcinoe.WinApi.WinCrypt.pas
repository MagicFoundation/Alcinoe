  end;
  SSL_KEY_PIN_EXTRA_CERT_CHAIN_POLICY_STATUS = _SSL_KEY_PIN_EXTRA_CERT_CHAIN_POLICY_STATUS;
  PSSL_KEY_PIN_EXTRA_CERT_CHAIN_POLICY_STATUS = ^_SSL_KEY_PIN_EXTRA_CERT_CHAIN_POLICY_STATUS;


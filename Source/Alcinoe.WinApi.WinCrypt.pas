  PCMC_TAGGED_CONTENT_INFO = ^_CMC_TAGGED_CONTENT_INFO;

type
  _CMC_TAGGED_OTHER_MSG = record
    dwBodyPartID: DWORD;
    pszObjId: LPSTR;

//  CMC_STATUS
//
//  Certificate Management Messages over CMS (CMC) Status.
//
//  pvStructInfo points to a CMC_STATUS_INFO.
//--------------------------------------------------------------------------
type
  _CMC_PEND_INFO = record
    PendToken: CRYPT_DATA_BLOB;

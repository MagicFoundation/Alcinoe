function CryptImportPublicKeyInfoEx(
           hCryptProv: HCRYPTPROV;
           dwCertEncodingType: DWORD;
           pInfo: PCERT_PUBLIC_KEY_INFO;
           aiKeyAlg: ALG_ID;

           pvStructInfo: Pvoid;
           pSignatureAlgorithm: PCRYPT_ALGORITHM_IDENTIFIER;
           pvHashAuxInfo: Pvoid;
           pbEncoded: PBYTE;
           pcbEncoded: PDWORD): LongBool; stdcall; external 'crypt32.dll';


const CRYPTNET_PRE_FETCH_AFTER_PUBLISH_PRE_FETCH_DIVISOR_VALUE_NAME = 'CryptnetPreFetchAfterPublishPreFetchDivisor';
// 10, where 12 hours / 10 = 72 minutes or 1.2 hours / 10 = 7.2 minutes

const CRYPTNET_PRE_FETCH_MIN_AFTER_NEXT_UPDATE_PRE_FETCH_PERIOD_SECONDS_VALUE_NAME = 'CryptnetPreFetchMinAfterNextUpdatePreFetchPeriodSeconds';
